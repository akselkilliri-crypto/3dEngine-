<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <android.opengl.GLSurfaceView
        android:id="@+id/glSurfaceView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Кнопка Детализация (Subdivide) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabSubdivide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:contentDescription="Subdivide"
        app:fabSize="normal"
        app:srcCompat="@android:drawable/ic_menu_add"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Кнопка Вытянуть/Вдавить (Extrude) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabExtrude"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:contentDescription="Extrude"
        app:fabSize="normal"
        app:srcCompat="@android:drawable/arrow_up_float"
        app:layout_constraintBottom_toTopOf="@id/fabSubdivide"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Кнопка Манипулятор (режим перемещения) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabManipulator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:contentDescription="Manipulator"
        app:fabSize="normal"
        app:srcCompat="@android:drawable/ic_menu_rotate"
        app:layout_constraintBottom_toTopOf="@id/fabExtrude"
        app:layout_constraintEnd_toEndOf="parent"
        app:backgroundTint="@color/design_default_color_primary" />

    <!-- Кнопка Удалить (Delete) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabDelete"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:contentDescription="Delete"
        app:fabSize="normal"
        app:srcCompat="@android:drawable/ic_menu_delete"
        app:layout_constraintBottom_toTopOf="@id/fabManipulator"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Кнопка Сгладить (Smooth) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabSmooth"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:contentDescription="Smooth"
        app:fabSize="normal"
        app:srcCompat="@android:drawable/ic_menu_slideshow"
        app:layout_constraintBottom_toTopOf="@id/fabDelete"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Кнопка Сброс (Reset) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabReset"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:contentDescription="Reset"
        app:fabSize="normal"
        app:srcCompat="@android:drawable/ic_menu_revert"
        app:layout_constraintBottom_toTopOf="@id/fabSmooth"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
